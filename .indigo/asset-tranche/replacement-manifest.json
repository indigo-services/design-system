  "followUpIntegration": [
    {
      "path": "packages/icons/src/symbols/Strapi.tsx",
      "reason": "The exported symbol component will need to be regenerated or manually updated after Strapi.svg is replaced."
    },
    {
      "path": "docs/.storybook/preview.tsx",
      "reason": "Brand title and URL are now pointed at Indigo, but the token colors remain Strapi-owned for this cycle."
    }
