      "status": "needs-regeneration",
      "promptRef": "legacy-brand-image",
      "usedBy": [
        "legacy docs asset; replace or retire in same cycle"
      ]
    },
    {
      "id": "brand-symbol-svg",
      "family": "brand-symbol",
      "repoPath": "packages/icons/assets/symbols/Strapi.svg",
      "stagingSourcePath": ".indigo/source-assets/packages/icons/assets/symbols/Strapi.svg",
      "importTargetPath": ".indigo/import-targets/packages/icons/assets/symbols/Strapi.svg",
